{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/(signup|login|dashboard|add|logout|demo|analytics|feedback|learn|portfolio|delete/.*|currency|course/.*|quiz/.*)",
      "destination": "/api/index.py"
    }
  ],
  "build": {
    "env": {
      "UV_LINK_MODE": "copy"
    }
  }
}
